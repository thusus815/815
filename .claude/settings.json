{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git stash*)",
      "Bash(gh issue list*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh issue view*)",
      "Bash(curl -s https://api.github.com/*)",
      "Bash(ls*)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git branch -D*)",
      "Bash(npx wrangler kv key delete*)",
      "Bash(npx wrangler secret delete*)"
    ]
  }
}
